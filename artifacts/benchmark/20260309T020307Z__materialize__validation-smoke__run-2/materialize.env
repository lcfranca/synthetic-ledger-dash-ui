# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=accounting-events-v1
LEDGER_ENTRIES_KAFKA_TOPIC=ledger-entries-v1
LEDGER_ENTRIES_KAFKA_PUBLISH_ENABLED=true
KAFKA_FANOUT_CONSUMER_ENABLED=true
KAFKA_FANOUT_GROUP_ID=ledger-fanout-clickhouse-v3
KAFKA_FANOUT_TARGET_BACKENDS=
KAFKA_FANOUT_AUTO_OFFSET_RESET=earliest
SCHEMA_MAJOR_VERSION=1

# Stack selection
# Active full stacks for this run. Accepted values: clickhouse, druid, pinot, materialize.
# Use a comma-separated list to enable more than one stack, for example: ACTIVE_STACKS=clickhouse,pinot
ACTIVE_STACKS=materialize
# Keep the OTEL collector on when you want producer -> writer ingestion enabled.
ENABLE_OTEL_COLLECTOR=true
# When true, make run also starts the synthetic event producer.
RUN_PRODUCER_ON_START=false

# Producer
PRODUCER_EVENTS_PER_SECOND=20
PRODUCER_COMPANY_ID=company-demo

# Storage writer
# TARGET_BACKENDS and KAFKA_FANOUT_TARGET_BACKENDS are derived automatically from ACTIVE_STACKS during make run/make populate.
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=ledger
CLICKHOUSE_USER=ledger_app
CLICKHOUSE_PASSWORD=ledger_app_pass
CLICKHOUSE_DIRECT_WRITE_ENABLED=false
CLICKHOUSE_READONLY_USER=ledger_ro
CLICKHOUSE_READONLY_PASSWORD=ledger_ro_pass
CLICKHOUSE_DBEAVER_HOST=localhost
CLICKHOUSE_DBEAVER_HTTP_PORT=8123
CLICKHOUSE_DBEAVER_NATIVE_PORT=9000

DRUID_ROUTER_URL=http://druid-router:8888
DRUID_OVERLORD_URL=http://druid-overlord:8081
DRUID_DATASOURCE=ledger_events
DRUID_KAFKA_CONSUMER_ENABLED=true
DRUID_KAFKA_USE_EARLIEST_OFFSET=false
DRUID_KAFKA_TOPIC=ledger-entries-v1
DRUID_DIRECT_WRITE_ENABLED=false
DRUID_SUPERVISOR_RETRY_SECONDS=5
DRUID_SUPERVISOR_MAX_ATTEMPTS=0
DRUID_USER=druid_app
DRUID_PASSWORD=druid_app_pass
DRUID_DBEAVER_HOST=localhost
DRUID_DBEAVER_PORT=8889

PINOT_CONTROLLER_URL=http://pinot-controller:9000
PINOT_BROKER_URL=http://pinot-broker:8099
PINOT_TABLE=ledger_events
PINOT_KAFKA_CONSUMER_ENABLED=true
PINOT_KAFKA_AUTO_OFFSET_RESET=largest
PINOT_BOOTSTRAP_RETRY_SECONDS=5
PINOT_BOOTSTRAP_MAX_ATTEMPTS=0
PINOT_DIRECT_WRITE_ENABLED=false
PINOT_USER=pinot_app
PINOT_PASSWORD=pinot_app_pass
PINOT_DBEAVER_HOST=localhost
PINOT_DBEAVER_PORT=8099

MATERIALIZE_ENABLED=true
MATERIALIZE_URL=postgresql://materialize@materialized:6875/materialize
MATERIALIZE_HOST=materialized
MATERIALIZE_PORT=6875
MATERIALIZE_HTTP_PORT=6877
MATERIALIZE_DATABASE=materialize
MATERIALIZE_SCHEMA=public
MATERIALIZE_USER=materialize
MATERIALIZE_PASSWORD=
MATERIALIZE_KAFKA_BROKER=kafka:9092
MATERIALIZE_KAFKA_TOPIC=ledger-entries-v1
MATERIALIZE_KAFKA_GROUP_ID_PREFIX=ledger-materialize
MATERIALIZE_BOOTSTRAP_RETRY_SECONDS=5
MATERIALIZE_BOOTSTRAP_MAX_ATTEMPTS=0
MATERIALIZE_BOOTSTRAP_START_TIMESTAMP_MS=
MATERIALIZE_EXPECTED_VIEW_LAG_MS=5000
MATERIALIZE_EXPECTED_FRESHNESS_MS=5000
MATERIALIZE_TARGET_HYDRATION_ROWS=1
MATERIALIZE_CLUSTER_REPLICAS=1
MATERIALIZE_VIEW_SCHEMA=public
MATERIALIZE_DBEAVER_HOST=localhost
MATERIALIZE_DBEAVER_PORT=6875

# API
# API_DEFAULT_BACKEND and API_ALLOWED_BACKENDS are derived automatically from ACTIVE_STACKS during make run/make populate.
API_REFRESH_INTERVAL_MS=1000
REALTIME_GATEWAY_GROUP_ID=realtime-gateway-v1
REALTIME_GATEWAY_AUTO_OFFSET_RESET=latest
REALTIME_GATEWAY_COALESCE_MS=250
REALTIME_GATEWAY_CLICKHOUSE_API_URL=http://api:8080
REALTIME_GATEWAY_DRUID_API_URL=http://api-druid:8080
REALTIME_GATEWAY_PINOT_API_URL=http://api-pinot:8080
REALTIME_GATEWAY_MATERIALIZE_API_URL=http://api-materialize:8080

# Resource caps calibrated for a local WSL with 15 GB RAM and 4 GB swap.
KAFKA_MEM_LIMIT=896m
KAFKA_CPU_LIMIT=1.0
CLICKHOUSE_MEM_LIMIT=2304m
CLICKHOUSE_CPU_LIMIT=2.0
DRUID_POSTGRES_MEM_LIMIT=384m
DRUID_POSTGRES_CPU_LIMIT=0.5
DRUID_COORDINATOR_XMS=192m
DRUID_COORDINATOR_XMX=192m
DRUID_COORDINATOR_MEM_LIMIT=384m
DRUID_COORDINATOR_CPU_LIMIT=0.5
DRUID_OVERLORD_XMS=256m
DRUID_OVERLORD_XMX=256m
DRUID_OVERLORD_MEM_LIMIT=512m
DRUID_OVERLORD_CPU_LIMIT=0.75
DRUID_BROKER_XMS=128m
DRUID_BROKER_XMX=128m
DRUID_BROKER_MEM_LIMIT=2048m
DRUID_BROKER_CPU_LIMIT=0.75
DRUID_HISTORICAL_XMS=512m
DRUID_HISTORICAL_XMX=512m
DRUID_HISTORICAL_MEM_LIMIT=1280m
DRUID_HISTORICAL_CPU_LIMIT=1.0
DRUID_MIDDLEMANAGER_XMS=512m
DRUID_MIDDLEMANAGER_XMX=512m
DRUID_MIDDLEMANAGER_MEM_LIMIT=1024m
DRUID_MIDDLEMANAGER_CPU_LIMIT=1.0
DRUID_ROUTER_XMS=128m
DRUID_ROUTER_XMX=128m
DRUID_ROUTER_MEM_LIMIT=256m
DRUID_ROUTER_CPU_LIMIT=0.5
PINOT_CONTROLLER_MEM_LIMIT=1280m
PINOT_CONTROLLER_CPU_LIMIT=1.0
PINOT_BROKER_MEM_LIMIT=1280m
PINOT_BROKER_CPU_LIMIT=1.0
PINOT_SERVER_MEM_LIMIT=1536m
PINOT_SERVER_CPU_LIMIT=1.5
OTEL_MEM_LIMIT=256m
OTEL_CPU_LIMIT=0.5
STORAGE_WRITER_MEM_LIMIT=640m
STORAGE_WRITER_CPU_LIMIT=1.0
API_MEM_LIMIT=320m
API_CPU_LIMIT=0.5
API_DRUID_MEM_LIMIT=320m
API_DRUID_CPU_LIMIT=0.5
API_PINOT_MEM_LIMIT=320m
API_PINOT_CPU_LIMIT=0.5
MATERIALIZE_MEM_LIMIT=2048m
MATERIALIZE_CPU_LIMIT=1.5
API_MATERIALIZE_MEM_LIMIT=352m
API_MATERIALIZE_CPU_LIMIT=0.75
REALTIME_GATEWAY_MEM_LIMIT=256m
REALTIME_GATEWAY_CPU_LIMIT=0.5
FRONTEND_MEM_LIMIT=160m
FRONTEND_CPU_LIMIT=0.25
FRONTEND_DRUID_MEM_LIMIT=160m
FRONTEND_DRUID_CPU_LIMIT=0.25
FRONTEND_PINOT_MEM_LIMIT=160m
FRONTEND_PINOT_CPU_LIMIT=0.25
FRONTEND_MATERIALIZE_MEM_LIMIT=160m
FRONTEND_MATERIALIZE_CPU_LIMIT=0.25
