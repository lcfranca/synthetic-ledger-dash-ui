{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synthetic-ledger.local/schemas/accounting-event-v1.json",
  "title": "AccountingEvent",
  "type": "object",
  "required": [
    "event_id",
    "schema_version",
    "event_type",
    "company_id",
    "tenant_id",
    "occurred_at",
    "ingested_at",
    "product_id",
    "warehouse_id",
    "quantity",
    "unit_price",
    "discount",
    "tax",
    "currency",
    "cost_basis",
    "cmv",
    "debit_account",
    "credit_account"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "schema_version": { "type": "string" },
    "event_type": { "type": "string", "enum": ["purchase", "sale", "stock_adjustment", "return", "payment", "refund"] },
    "company_id": { "type": "string" },
    "tenant_id": { "type": "string" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "ingested_at": { "type": "string", "format": "date-time" },
    "product_id": { "type": "string" },
    "supplier_id": { "type": ["string", "null"] },
    "customer_id": { "type": ["string", "null"] },
    "warehouse_id": { "type": "string" },
    "quantity": { "type": "number" },
    "unit_price": { "type": "number" },
    "discount": { "type": "number" },
    "tax": { "type": "number" },
    "currency": { "type": "string" },
    "cost_basis": { "type": "number" },
    "cmv": { "type": "number" },
    "debit_account": { "type": "string" },
    "credit_account": { "type": "string" },
    "channel": { "type": "string" }
  }
}
